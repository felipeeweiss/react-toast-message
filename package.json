{
  "name": "react-toast-message",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/react-toast-message.umd.cjs",
  "module": "./dist/react-toast-message.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/react-toast-message.js",
      "require": "./dist/react-toast-message.umd.cjs"
    }
  },
  "sideEffects": [
    "*.css",
    "./dist/react-toast-message.css"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.app.json",
    "lint": "eslint ."
  },
  "peerDependencies": {
    "@tailwindcss/vite": "^4",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "tailwindcss": "^4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "prettier": "3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  },
  "dependencies": {
    "clsx": "^2.1.1"
  }
}
